APP_NAME=ShellBot
APP_BASE_URL=http://127.0.0.1:8088
DATABASE_URL=sqlite:///./shellbot.db
TENANTS_FILE=config/tenants.example.json

META_VERIFY_TOKEN=change-me
META_ACCESS_TOKEN=
META_API_VERSION=v20.0
